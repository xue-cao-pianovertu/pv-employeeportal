{
  "routes": [
    {
      "route": "/register",
      "rewrite": "/index.html"
    },
    {
      "route": "/login",
      "rewrite": "/login-client.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard-client.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{html,js,css,png,jpg,jpeg,svg,ico,woff,woff2}"
    ]
  },
  "globalHeaders": {
    "Cache-Control": "no-store"
  },
  "responseOverrides": {
    "401": {
      "rewrite": "/login-staff.html"
    }
  }
}
